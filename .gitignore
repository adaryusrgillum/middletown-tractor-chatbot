# --- Python ---
.venv/
__pycache__/
*.pyc

# --- Node ---
node_modules/

# --- Logs ---
*.log
scraper/*.log
scraper/download.log
scraper/scrape_full.log

# --- Android build outputs (regenerated by Gradle) ---
android/build/
android/.gradle/
android/app/build/
android/local.properties

# --- Capacitor sync targets (web assets copied in by `cap copy`) ---
android/app/src/main/assets/public/

# --- Generated site bundle (rebuild from raw JSON via build_site.py) ---
site_bundle/images/
site_bundle/pages/
site_bundle/assets/
site_bundle/index.html
site_bundle/manifest.json

# --- APK output (distributed via GitHub Releases, not git) ---
*.apk

# --- Env / secrets ---
.env

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
