# Copy to .env (gitignored) and fill in.
# Used by backend/server.py via python-dotenv.

# --- Service request push notifications (ntfy.sh) ---
# Pick a hard-to-guess topic name. Subscribe to the same topic in the ntfy
# mobile app (iOS / Android) to receive a push whenever someone submits
# the Schedule Service form.
NTFY_TOPIC=mts-svc-CHANGEME-7f2k9q1x
NTFY_URL=https://ntfy.sh

# --- Chatbot LLM (only needed if running the /api/chat endpoint) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_KEEP_ALIVE=30m
